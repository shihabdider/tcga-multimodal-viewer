{
  "version": 1,
  "targets": [
    {
      "label": "tcga-multimodal-viewer",
      "path": ".",
      "verifiers": {
        "compile": null,
        "test": {
          "argv": [
            "bash",
            "-lc",
            "if find . -type f \\( -name '*.test.ts' -o -name '*.test.tsx' -o -name '*.test.js' -o -name '*.test.jsx' -o -name '*.spec.ts' -o -name '*.spec.tsx' -o -name '*.spec.js' -o -name '*.spec.jsx' \\) | grep -q .; then bun test; else echo 'No tests found yet; skipping bun test.'; fi"
          ]
        },
        "check": null,
        "lint": {
          "check": null,
          "fix": null
        }
      },
      "hooks": {
        "stubber_post": [],
        "implementer_post": [
          {
            "verifier": "test"
          }
        ],
        "layer_post": [
          {
            "verifier": "test"
          }
        ],
        "abstractor_post": [
          {
            "verifier": "test"
          }
        ],
        "final_preverify": [
          {
            "verifier": "test"
          }
        ]
      }
    }
  ]
}
